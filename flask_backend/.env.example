FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# SQLite default (recommended for demo). For Postgres:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/rankdb
DATABASE_URL=sqlite:///rankdb.sqlite3

# Optional LLM keys (used for learning map generation)
OPENAI_API_KEY=
GROQ_API_KEY=
LLM_PROVIDER=template   # template | openai | groq
